# Server-only credentials for on-demand climate explanations.
# Never expose this key through a NEXT_PUBLIC_ variable.
AI_PROVIDER=openrouter
AI_API_KEY=
AI_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# OpenAI is also supported: use AI_PROVIDER=openai and an OpenAI model/key.
# Existing OPENAI_API_KEY and OPENAI_MODEL configurations remain compatible.

# Best-effort per-instance burst protection for the AI route.
AI_RATE_LIMIT_MAX_REQUESTS=5
AI_RATE_LIMIT_WINDOW_SECONDS=60
